# --------------------------------------------------------------------
# Developer scratch files — JANGAN taruh di root proyek!
# Folder scripts/dev/ boleh di-commit untuk script yang berguna berulang,
# tapi backup data (JSON/SQL/ZIP) di dalam scripts/dev/ tetap di-ignore.
# --------------------------------------------------------------------
/scripts/dev/backups/*
!/scripts/dev/backups/.gitkeep
/scripts/dev/**/*.sql
/scripts/dev/**/*.zip
/scripts/dev/**/*.tar.gz
/scripts/dev/**/*backup*.json

