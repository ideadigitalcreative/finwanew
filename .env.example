APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =====================================================================
# Google OAuth Configuration
# =====================================================================
# Dapatkan credentials dari: https://console.cloud.google.com/apis/credentials
# Pastikan redirect URI terdaftar: {APP_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# =====================================================================
# Google Analytics Configuration
# =====================================================================
# Dapatkan Measurement ID dari: https://analytics.google.com/
# Format: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=

# =====================================================================
# Facebook Pixel Configuration
# =====================================================================
# Dapatkan Pixel ID dari: https://business.facebook.com/events_manager
FACEBOOK_PIXEL_ID=

VITE_APP_NAME="${APP_NAME}"

# =====================================================================
# AI/LLM Configuration
# =====================================================================

# Pilih provider: ollama, openrouter, atau openai
AI_PROVIDER=ollama

# Ollama Configuration (untuk local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_VISION_MODEL=qwen2.5-vl

# OpenRouter Configuration (alternatif)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# OpenAI Configuration (alternatif)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# API Keys untuk services
AI_PROCESSOR_API_KEY=ai_processor_api_key_123
OCR_WORKER_API_KEY=ocr_worker_api_key_123

# WhatsApp Gateway Configuration
WHATSAPP_ENGINE_URL=http://localhost:3004
WHATSAPP_ENGINE_API_KEY=whatsapp_gateway_api_key_123

# =====================================================================
# FinWa-AI v2 Configuration (EXTERNAL SERVICE)
# =====================================================================
# FinWa-AI is a separate application running on its own server/domain.
# It provides lightweight, rule-based NLU for WhatsApp finance messages.
# Much faster than LLM-based processing (~100ms vs 5-30s)
#
# Deployment options:
#   - Separate VPS: https://ai.finwa.com or http://your-ai-vps-ip:8000
#   - Same VPS different port: http://localhost:8003
#   - Docker: http://finwa-ai:8000
#
# Set FINWA_AI_ENABLED=false to disable and use AIProcessor only
# =====================================================================

# Production example (separate domain):
# FINWA_AI_URL=https://ai.finwa.com

# Development example (local):
FINWA_AI_URL=http://localhost:8000

FINWA_AI_TIMEOUT=30
FINWA_AI_ENABLED=true

# Lampirkan kontrak hutang/piutang (category_type + schema hint) ke body POST FinWa-AI /process/text
FINWA_AI_SEND_HP_CONTRACT=true

# =====================================================================
# GROQ LLM - BACKUP AI (Llama via Groq)
# =====================================================================
# Groq digunakan sebagai backup untuk hal yang FinWa-AI tidak bisa:
# - Jawab pertanyaan umum keuangan
# - Generate analisis/insight mendalam
# - Smart fallback classifier
#
# Mendukung multiple API key (pisah dengan koma) untuk rotasi otomatis.
# Dapatkan API key di: https://console.groq.com
# Model: llama-3.1-8b-instant (GRATIS di tier basic)
# =====================================================================

GROQ_LLM_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GROQ_LLM_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_LLM_TIMEOUT=30
GROQ_LLM_ENABLED=true

# =====================================================================
# Gemini AI - Scan Struk (Gemini Vision)
# =====================================================================
# Digunakan untuk membaca gambar struk belanja langsung tanpa OCR.
# Dapatkan API key di: https://aistudio.google.com/apikey
# Model: gemini-2.5-flash
# =====================================================================

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=60
# Kosongkan jika langsung ke Google. Isi proxy URL jika VPS di-block region.
# Contoh Cloudflare Worker: https://gemini-proxy.your-worker.workers.dev/v1beta/models
GEMINI_BASE_URL=

